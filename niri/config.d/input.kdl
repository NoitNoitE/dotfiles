input {
    keyboard {
      //xkb {
      //
	  //}
    }

    touchpad {
        tap
        dwt
        natural-scroll
        accel-profile "flat"
        scroll-method "two-finger"
        middle-emulation
		//disabled-on-external-mouse
    }

    mouse {
        accel-profile "flat"
    }

    trackpoint {}

    warp-mouse-to-focus
}

gestures {
    hot-corners {
        off
    }
}
